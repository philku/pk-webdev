# Production Environment Variables
# Diese Datei auf dem Server als .env.local ablegen und die Werte anpassen.
# NIEMALS echte Secrets committen!

APP_ENV=prod
APP_SECRET=HIER_EINEN_ZUFAELLIGEN_STRING_GENERIEREN
APP_SHARE_DIR=var/share

# Domain für URL-Generierung in CLI-Befehlen (z.B. Cron Jobs)
DEFAULT_URI=https://deine-domain.de

# MariaDB — Datenbank-Zugangsdaten aus Plesk übernehmen
DATABASE_URL="mysql://DB_USER:DB_PASSWORT@127.0.0.1:3306/DB_NAME?serverVersion=11.8.0-mariadb&charset=utf8mb4"

# Redis — Standard-Port auf localhost
REDIS_URL=redis://127.0.0.1:6379

# SetlistFM API (Metallica Konzerte)
SETLISTFM_API_KEY=dein-api-key

# Spotify API (Metallica Discography)
SPOTIFY_CLIENT_ID=dein-client-id
SPOTIFY_CLIENT_SECRET=dein-client-secret

# IGDB / Twitch API (Game Advisor)
IGDB_CLIENT_ID=dein-twitch-client-id
IGDB_CLIENT_SECRET=dein-twitch-client-secret

# Google Gemini API (KI-Empfehlungen)
GEMINI_API_KEY=dein-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
