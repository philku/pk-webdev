{% extends 'base.html.twig' %}

{% block title %}{{ album.name }} — Metallica{% endblock %}

{% block body %}
    <section class="py-12">
        {# Zurück-Navigation #}
        <a href="{{ path('app_metallica') }}"
           class="text-sm font-medium text-accent-600 hover:text-accent-700 transition-colors">
            &larr; Zurück zu Metallica Universe
        </a>

        {# Album Header: Cover + Info #}
        <div class="mt-6 flex flex-col gap-6 sm:flex-row sm:items-start">
            {# Cover #}
            {% if album.image %}
                <div class="shrink-0 w-48 sm:w-56">
                    <img src="{{ album.image }}"
                         alt="{{ album.name }}"
                         class="w-full rounded-xl shadow-lg">
                </div>
            {% endif %}

            {# Info #}
            <div class="min-w-0">
                <h1 class="font-heading text-3xl text-warm-900 sm:text-4xl">{{ album.name }}</h1>
                <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-sm text-warm-500">
                    <span>{{ album.release_date[:4] }}</span>
                    {% if album.label %}
                        <span>{{ album.label }}</span>
                    {% endif %}
                    <span>{{ album.total_tracks }} Tracks</span>
                    {# Gesamtdauer berechnen #}
                    {% set total_ms = 0 %}
                    {% for track in album.tracks %}
                        {% set total_ms = total_ms + track.duration_ms %}
                    {% endfor %}
                    {% set total_minutes = (total_ms / 60000)|round(0, 'floor') %}
                    <span>{{ total_minutes }} min</span>
                </div>

                {# Spotify Link #}
                {% if album.spotify_url %}
                    <a href="{{ album.spotify_url }}"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="mt-4 inline-flex items-center gap-2 rounded-full bg-[#1DB954] px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-[#1ed760]">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                        </svg>
                        Auf Spotify anhören
                    </a>
                {% endif %}
            </div>
        </div>
    </section>

    {# --- Tracklist --- #}
    <section class="pb-16">
        <h2 class="font-heading text-2xl text-warm-900">Tracklist</h2>
        <div class="mt-4 divide-y divide-warm-200 rounded-xl border border-warm-200">
            {% for track in album.tracks %}
                <div class="flex items-center gap-4 px-4 py-3 transition-colors hover:bg-warm-50">
                    {# Track-Nummer #}
                    <span class="w-6 shrink-0 text-right text-sm text-warm-400">
                        {{ track.number }}
                    </span>

                    {# Track-Name + Play Count Badge #}
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-medium text-warm-900 truncate">
                                {{ track.name }}
                            </span>
                        </div>
                    </div>

                    {# Dauer (m:ss) #}
                    {% set minutes = (track.duration_ms / 60000)|round(0, 'floor') %}
                    {% set seconds = ((track.duration_ms % 60000) / 1000)|round(0, 'floor') %}
                    <span class="shrink-0 text-sm text-warm-400">
                        {{ minutes }}:{{ seconds < 10 ? '0' ~ seconds : seconds }}
                    </span>

                    {# Spotify Link #}
                    {% if track.spotify_url %}
                        <a href="{{ track.spotify_url }}"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="shrink-0 text-warm-400 transition-colors hover:text-[#1DB954]"
                           title="Auf Spotify anhören">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                            </svg>
                        </a>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        {# Copyright #}
        {% if album.copyrights is not empty %}
            <div class="mt-4 space-y-1">
                {% for copyright in album.copyrights %}
                    <p class="text-xs text-warm-400">
                        {{ copyright.type == 'P' ? '℗' : '©' }} {{ copyright.text }}
                    </p>
                {% endfor %}
            </div>
        {% endif %}
    </section>
{% endblock %}
