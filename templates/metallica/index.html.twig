{% extends 'base.html.twig' %}

{% block title %}Metallica Universe{% endblock %}

{# Leaflet loaded via ImportMap — Stimulus controller imports JS + CSS as module dependency #}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Tech Demo
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Metallica Universe</h1>
        <p class="mt-4 max-w-lg text-warm-500 leading-relaxed">
            Konzerte weltweit, Discography und Live-Statistiken.
            Daten von setlist.fm und Spotify APIs.
        </p>

        {# ===== Under the Hood ===== #}
        {% embed 'components/_unter_der_haube.html.twig' %}
            {% block items %}
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">Spotify API + OAuth 2.0</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        Die Discography wird über die Spotify Web API geladen. Authentifizierung per
                        OAuth 2.0 Client Credentials Flow — Token wird automatisch gecacht und bei Ablauf erneuert.
                    </p>
                </div>
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">setlist.fm API</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        Über 2.000 Konzerte werden beim ersten Steienaufruf seitenweise von der setlist.fm API geladen
                        und gecacht. Retry-Logik mit Exponential Backoff fängt Rate Limits ab. Die Live-Song-Statistik
                        wird aus allen Setlists ausgewertet und als Top-10-Ranking aufbereitet.
                    </p>
                </div>
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">Redis Caching + Delta-Check</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        Alle API-Daten werden 30 Tage in Redis gecacht. Ein Delta-Check prüft bei jedem Seitenaufruf
                        mit nur einem API-Call ob neue Konzerte dazugekommen sind — statt alle Seiten neu zu laden,
                        werden nur die neuen Einträge nachgeladen und in den bestehenden Cache eingefügt.
                    </p>
                </div>
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">Leaflet Maps + Stimulus</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        Die interaktive Weltkarte nutzt Leaflet.js, gesteuert über einen Stimulus Controller.
                        Auf Mobilgeräten öffnet sich beim Klick auf einen Veranstaltungsort ein swipebares Bottom Sheet
                        statt Popups — mit Touch-Events und proportionaler Backdrop-Opacity.
                    </p>
                </div>
            {% endblock %}
        {% endembed %}
    </section>

    {# Stimulus controller — URL value passed via Twig's path() #}
    <div class="py-8 border-t border-warm-200"
         data-controller="metallica-map"
         data-metallica-map-url-value="{{ path('app_metallica_concerts') }}">

        {# Stat tiles — each target accessed via this.<name>Target in controller #}
        <section class="grid grid-cols-2 gap-4 sm:grid-cols-4">
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statTotal">—</p>
                <p class="mt-1 text-xs text-warm-500">Konzerte</p>
            </div>
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statCountries">—</p>
                <p class="mt-1 text-xs text-warm-500">Länder</p>
            </div>
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statCities">—</p>
                <p class="mt-1 text-xs text-warm-500">Städte</p>
            </div>
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statYears">—</p>
                <p class="mt-1 text-xs text-warm-500">Jahre aktiv</p>
            </div>
        </section>

        {# --- Map --- #}
        <section class="mt-8">
            {# Loading indicator — hidden by controller once data arrives #}
            <div data-metallica-map-target="loading"
                 class="flex items-center justify-center rounded-xl border border-warm-200 bg-warm-50 py-20">
                <div class="text-center">
                    <div class="mx-auto h-8 w-8 animate-spin rounded-full border-4 border-warm-300 border-t-accent-600"></div>
                    <p class="mt-4 text-sm text-warm-500">Lade Konzertdaten...</p>
                </div>
            </div>

            {# Map container — hidden initially, shown by controller.
               relative z-0 creates a stacking context so Leaflet's z-indices (400+) don't overlap the sticky header (z-50). #}
            <div data-metallica-map-target="mapContainer"
                 class="relative z-0 hidden h-[500px] rounded-xl border border-warm-200 sm:h-[600px]"></div>

            {# Progress bar — shows page-by-page loading progress, hidden when done #}
            <div data-metallica-map-target="progress"
                 class="hidden mt-4">
                <div class="flex items-center gap-3">
                    <div class="flex-1 h-2 rounded-full bg-warm-200 overflow-hidden">
                        <div data-metallica-map-target="progressBar"
                             class="h-full rounded-full bg-accent-600 transition-all duration-300"
                             style="width: 0%"></div>
                    </div>
                    <span data-metallica-map-target="progressText"
                          class="text-xs text-warm-500 whitespace-nowrap"></span>
                </div>
            </div>
        </section>

        {# --- Concert list below the map --- #}
        <section class="mt-8">
            <h2 class="font-heading text-2xl text-warm-900">Letzte Konzerte</h2>
            <div data-metallica-map-target="concertList" class="mt-4 space-y-3">
                {# Populated by controller #}
            </div>
        </section>

        {# --- Mobile Bottom Sheet --- #}
        <div data-metallica-map-target="sheetBackdrop"
             data-action="click->metallica-map#closeSheet"
             class="fixed inset-0 z-[999] bg-warm-900/40 opacity-0 pointer-events-none transition-opacity duration-300 sm:hidden"></div>

        <div data-metallica-map-target="bottomSheet"
             class="fixed inset-x-0 bottom-0 z-[1000] translate-y-full transition-transform duration-300 ease-out sm:hidden">
            <div class="rounded-t-2xl bg-warm-50 shadow-[0_-4px_24px_rgba(0,0,0,0.12)] max-h-[70vh] flex flex-col">
                <div class="flex justify-center pt-3 pb-1 cursor-grab"
                     data-action="touchstart->metallica-map#onSwipeStart touchmove->metallica-map#onSwipeMove touchend->metallica-map#onSwipeEnd">
                    <div class="h-1 w-10 rounded-full bg-warm-300"></div>
                </div>
                <div class="px-5 pb-3 border-b border-warm-200">
                    <h3 data-metallica-map-target="sheetTitle"
                        class="font-heading text-lg text-warm-900"></h3>
                    <p data-metallica-map-target="sheetSubtitle"
                       class="text-sm text-warm-500 mt-0.5"></p>
                </div>
                <div data-metallica-map-target="sheetList"
                     class="overflow-y-auto overscroll-contain px-5 py-3 space-y-1">
                </div>
            </div>
        </div>
    </div>

    {# ========== MOST PLAYED SONGS ========== #}
    <section class="mt-10 pb-12"
             data-controller="metallica-discography"
             data-metallica-discography-url-value="{{ path('app_metallica_discography_stats') }}">
        <h2 class="font-heading text-2xl text-warm-900">Meistgespielte Songs live</h2>
        <p class="mt-2 text-xs text-warm-400">
            Top 10 — basierend auf setlist.fm Konzertdaten
        </p>
        <div data-metallica-discography-target="playedContainer" class="mt-4"></div>
    </section>

    {# ========== DISCOGRAPHY ========== #}
    <section class="pb-16">
        <h2 class="font-heading text-2xl text-warm-900">Discography</h2>

        <p class="mt-2 text-xs text-warm-400">
            {{ albums|length }} Alben — Daten aus der Spotify API.
        </p>

        {# Album Grid #}
        <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
            {% for album in albums %}
                <a href="{{ path('app_metallica_album', {id: album.id}) }}"
                   class="group rounded-xl border border-warm-200 overflow-hidden transition-all hover:border-accent-500 hover:shadow-lg hover:shadow-accent-500/5">
                    {% if album.image %}
                        <div class="aspect-square overflow-hidden bg-warm-100">
                            <img src="{{ album.image }}"
                                 alt="{{ album.name }}"
                                 class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                 loading="lazy">
                        </div>
                    {% else %}
                        <div class="aspect-square bg-warm-200 flex items-center justify-center">
                            <span class="text-warm-400 text-sm">Kein Cover</span>
                        </div>
                    {% endif %}
                    <div class="p-3">
                        <h3 class="font-heading text-sm text-warm-900 leading-tight truncate">
                            {{ album.name }}
                        </h3>
                        <p class="mt-1 text-xs text-warm-500">
                            {{ album.release_date[:4] }} · {{ album.total_tracks }} Tracks
                        </p>
                    </div>
                </a>
            {% endfor %}
        </div>
    </section>

{% endblock %}
