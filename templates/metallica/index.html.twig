{% extends 'base.html.twig' %}

{% block title %}Metallica Universe{% endblock %}

{#
    Kein {% block stylesheets %} und {% block javascripts %} mehr nötig!
    Leaflet wird jetzt per ImportMap geladen (siehe importmap.php).
    Der Stimulus Controller (metallica_map_controller.js) importiert
    Leaflet JS + CSS automatisch als Modul-Abhängigkeit.
#}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Tech Demo
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Metallica Universe</h1>
        <p class="mt-4 max-w-lg text-warm-500 leading-relaxed">
            Alle Metallica-Konzerte weltweit auf einer interaktiven Karte.
            Daten von der setlist.fm API, Karte mit Leaflet &amp; OpenStreetMap.
        </p>
    </section>

    {# --- Stimulus Controller aktivieren ---
         data-controller="metallica-map" verbindet dieses <div> mit dem
         metallica_map_controller.js. Stimulus erkennt den Namen automatisch:
         Dateiname metallica_map_controller.js → Controller-Name metallica-map

         data-metallica-map-url-value übergibt die API-URL an den Controller.
         Im Controller ist das dann this.urlValue (ein String).
         Vorteil: Die URL wird von Twig's path() generiert — kein Hardcoding.
    #}
    <div data-controller="metallica-map"
         data-metallica-map-url-value="{{ path('app_metallica_concerts') }}">

        {# --- Statistik-Kacheln ---
             Jedes data-metallica-map-target="..." verbindet das Element
             mit einem Target im Controller. Der Controller greift dann
             per this.statTotalTarget etc. darauf zu.
        #}
        <section class="grid grid-cols-2 gap-4 sm:grid-cols-4">
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statTotal">—</p>
                <p class="mt-1 text-xs text-warm-500">Konzerte</p>
            </div>
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statCountries">—</p>
                <p class="mt-1 text-xs text-warm-500">Laender</p>
            </div>
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statCities">—</p>
                <p class="mt-1 text-xs text-warm-500">Staedte</p>
            </div>
            <div class="rounded-xl border border-warm-200 p-5 text-center">
                <p class="text-2xl font-heading text-warm-900" data-metallica-map-target="statYears">—</p>
                <p class="mt-1 text-xs text-warm-500">Jahre aktiv</p>
            </div>
        </section>

        {# --- Karte --- #}
        <section class="mt-8">
            {# Loading-Indikator — wird vom Controller ausgeblendet sobald Daten da sind #}
            <div data-metallica-map-target="loading"
                 class="flex items-center justify-center rounded-xl border border-warm-200 bg-warm-50 py-20">
                <div class="text-center">
                    <div class="mx-auto h-8 w-8 animate-spin rounded-full border-4 border-warm-300 border-t-accent-600"></div>
                    <p class="mt-4 text-sm text-warm-500">Lade Konzertdaten...</p>
                </div>
            </div>

            {# Die eigentliche Karte — anfangs versteckt, Controller blendet sie ein #}
            <div data-metallica-map-target="mapContainer"
                 class="hidden h-[500px] rounded-xl border border-warm-200 sm:h-[600px]"></div>
        </section>

        {# --- Konzertliste unter der Karte --- #}
        <section class="mt-8 pb-12">
            <h2 class="font-heading text-2xl text-warm-900">Letzte Konzerte</h2>
            <div data-metallica-map-target="concertList" class="mt-4 space-y-3">
                {# Wird vom Controller befuellt #}
            </div>
        </section>

        {# --- Mobile Bottom Sheet ---
             Auf Mobilgeräten sind Leaflet-Popups schlecht bedienbar:
             zu klein, schwer zu scrollen, winzige Touch-Targets.
             Stattdessen zeigen wir ein Bottom Sheet (wie Google Maps),
             das vom unteren Bildschirmrand hochslided.
             Wird nur auf Screens < 640px (sm Breakpoint) benutzt.

             WICHTIG: Backdrop und Sheet sind GETRENNTE Elemente!
             Backdrop darf NICHT innerhalb eines transform-Parents liegen,
             weil CSS "fixed" innerhalb eines transformierten Elements
             sich nicht mehr auf den Viewport bezieht, sondern auf den Parent.
             → Backdrop wäre verschoben und würde hinter den Rundungen durchscheinen.
        #}

        {# Backdrop — eigenes Element, nicht im Sheet-Wrapper!
             Liegt direkt auf dem Viewport (fixed inset-0) ohne transformierten Parent.
             Klick/Tap darauf schließt das Sheet. #}
        <div data-metallica-map-target="sheetBackdrop"
             data-action="click->metallica-map#closeSheet"
             class="fixed inset-0 z-[999] bg-warm-900/40 opacity-0 pointer-events-none transition-opacity duration-300 sm:hidden"></div>

        {# Sheet-Container — slided von unten rein.
             Kann per Swipe nach unten geschlossen werden (Touch-Events im Controller). #}
        <div data-metallica-map-target="bottomSheet"
             class="fixed inset-x-0 bottom-0 z-[1000] translate-y-full transition-transform duration-300 ease-out sm:hidden">
            <div class="rounded-t-2xl bg-warm-50 shadow-[0_-4px_24px_rgba(0,0,0,0.12)] max-h-[70vh] flex flex-col">
                {# Drag-Handle — visueller Hinweis + Swipe-Bereich #}
                <div class="flex justify-center pt-3 pb-1 cursor-grab"
                     data-action="touchstart->metallica-map#onSwipeStart touchmove->metallica-map#onSwipeMove touchend->metallica-map#onSwipeEnd">
                    <div class="h-1 w-10 rounded-full bg-warm-300"></div>
                </div>

                {# Header: Venue-Name + Stadt #}
                <div class="px-5 pb-3 border-b border-warm-200">
                    <h3 data-metallica-map-target="sheetTitle"
                        class="font-heading text-lg text-warm-900"></h3>
                    <p data-metallica-map-target="sheetSubtitle"
                       class="text-sm text-warm-500 mt-0.5"></p>
                </div>

                {# Konzert-Liste — scrollbar bei vielen Einträgen #}
                <div data-metallica-map-target="sheetList"
                     class="overflow-y-auto overscroll-contain px-5 py-3 space-y-1">
                    {# Wird vom Controller befuellt #}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
