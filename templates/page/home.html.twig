{% extends 'base.html.twig' %}

{% block title %}Philipp Küchau{% endblock %}

{% block body %}
    {# Hero — terminal window with subtle CRT atmosphere #}
    <section class="terminal-hero group/terminal relative overflow-hidden rounded-2xl shadow-2xl shadow-warm-900/50 ring-1 ring-white/[0.08]"
             data-controller="terminal">

        {# Layered background: base + radial glow + scanlines #}
        <div class="absolute inset-0 bg-[#131216]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_20%,rgba(13,148,136,0.06),transparent_60%)]"></div>
        <div class="terminal-scanlines absolute inset-0 pointer-events-none opacity-[0.03]" aria-hidden="true"></div>

        {# Terminal title bar #}
        <div class="relative flex items-center border-b border-white/[0.06] px-5 py-3">
            <div class="flex items-center gap-2">
                <span class="h-[11px] w-[11px] rounded-full bg-[#ff5f57]"></span>
                <span class="h-[11px] w-[11px] rounded-full bg-[#febc2e]"></span>
                <span class="h-[11px] w-[11px] rounded-full bg-[#28c840]"></span>
            </div>
            <span class="ml-4 font-mono text-[11px] tracking-wide text-white/25">~/pk-webdev</span>
        </div>

        {# Terminal body #}
        <div class="relative px-5 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12 font-mono text-sm leading-relaxed">

            {# === Command === #}
            <p class="flex items-center gap-2">
                <span class="text-accent-400 text-xs">❯</span>
                <span class="text-white/50">cat</span>
                <span class="text-white/70">README.md</span>
            </p>

            {# === Separator line (like markdown hr) === #}
            <div class="mt-5 mb-6 h-px bg-gradient-to-r from-white/[0.06] via-white/[0.1] to-transparent"></div>

            {# === Output: photo + info === #}
            <div class="flex flex-col items-center gap-8 sm:flex-row sm:items-center lg:gap-12">

                {# Photo with accent glow #}
                <div class="relative shrink-0">
                    <div class="absolute -inset-1 rounded-full bg-accent-600/10 blur-xl"></div>
                    <img
                        src="{{ asset('images/Portrait_480px.jpeg') }}"
                        srcset="{{ asset('images/Portrait_480px.jpeg') }} 480w, {{ asset('images/Portrait_720px.jpeg') }} 720w"
                        alt="Philipp Küchau — Fullstack Entwickler"
                        width="480"
                        height="360"
                        fetchpriority="high"
                        decoding="async"
                        sizes="(min-width: 1024px) 240px, (min-width: 640px) 208px, 192px"
                        class="relative h-44 w-44 rounded-full object-cover ring-[1.5px] ring-white/[0.12] sm:h-52 sm:w-52 lg:h-60 lg:w-60"
                    >
                </div>

                {# Info block #}
                <div>
                    <h1 class="font-heading text-[1.65rem] font-semibold tracking-tight text-white/90 sm:text-3xl lg:text-[2rem]">
                        Philipp Küchau
                    </h1>
                    <p class="mt-1.5 text-[14px] font-medium tracking-wide text-accent-400/90">
                        Fullstack Entwickler · Berlin
                    </p>

                    {# Key-value grid #}
                    <div class="mt-5 grid grid-cols-[auto_1fr] gap-x-5 gap-y-1 text-[14px]">
                        <span class="text-white/30">Kundenprojekt</span>
                        <a href="https://tunero.de" target="_blank" rel="noopener" class="text-accent-400/80 transition-colors hover:text-accent-300">tunero.de</a>
                        <span class="text-white/30">Background</span>
                        <span class="text-white/60">Mathematik · Economics · IT-Projektmanagement</span>
                        <span class="text-white/30">GitHub</span>
                        <a href="https://github.com/philku" target="_blank" rel="noopener" class="text-accent-400/80 transition-colors hover:text-accent-300">github.com/philku</a>
                        <span class="text-white/30">E-Mail</span>
                        <a href="mailto:p.kuechau@gmx.de" class="text-accent-400/80 transition-colors hover:text-accent-300">p.kuechau@gmx.de</a>
                        <span class="text-white/30">Status</span>
                        <span class="font-medium text-emerald-400">verfügbar</span>
                    </div>

                    {# CTA buttons #}
                    <div class="mt-7 flex flex-wrap gap-3">
                        <a href="/downloads/Lebenslauf_Kuechau-Philipp_philkude.pdf" target="_blank" rel="noopener" class="group/btn inline-flex items-center gap-2 rounded-lg bg-accent-600/90 px-5 py-2.5 text-[14px] font-semibold text-white shadow-md shadow-accent-600/10 transition-all hover:bg-accent-500/80">
                            Lebenslauf
                            <span class="transition-transform group-hover/btn:translate-y-0.5">↓</span>
                        </a>
                        <a href="{{ path('app_demos') }}" class="group/btn inline-flex items-center gap-2 rounded-lg border border-white/[0.08] bg-white/[0.03] px-5 py-2.5 text-[14px] font-semibold text-white/60 transition-all hover:border-white/[0.15] hover:bg-white/[0.06] hover:text-white/80">
                            Tech Demos
                            <span class="transition-transform group-hover/btn:translate-x-0.5">→</span>
                        </a>
                    </div>
                </div>
            </div>

            {# === Interactive output area === #}
            <div data-terminal-target="output"></div>

            {# === Prompt with interactive input === #}
            <div class="mt-8 flex items-center min-h-[24px]" data-terminal-target="prompt">
                <span class="text-accent-400 text-xs leading-none mr-2">❯</span>
                <span class="text-white/70 whitespace-pre" data-terminal-target="input"></span><span class="terminal-cursor h-[18px] w-[8px] bg-white/40" data-terminal-target="cursor"></span>
                <input type="text" class="sr-only" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" data-terminal-target="hiddenInput">
            </div>
        </div>

        {# Terminal status bar #}
        <div class="relative flex flex-wrap items-center justify-between gap-x-4 border-t border-white/[0.06] px-5 py-1.5 font-mono text-[11px] text-white/20">
            <span>HTTP/1.1 200 OK</span>
            <span>Content-Type: developer/fullstack · Cache: warm</span>
        </div>
    </section>

    {# Tech stack #}
    <section class="py-20" id="tech-stack">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Technologien
        </p>
        <h2 class="mt-3 font-heading text-3xl text-warm-900">Tech Stack</h2>

        {% set categories = [
            { label: 'Backend', items: [
                { name: 'PHP', logo: 'php' },
                { name: 'Symfony', logo: 'symfony' },
                { name: 'Pimcore', logo: 'pimcore-icon' },
                { name: 'Twig', logo: 'twig', logoExt: 'png' },
            ] },
            { label: 'Frontend', items: [
                { name: 'HTML', logo: 'html5' },
                { name: 'JavaScript', logo: 'javascript' },
                { name: 'Tailwind CSS', logo: 'tailwindcss' },
                { name: 'Stimulus', logo: 'stimulus' },
                { name: 'Turbo', logo: 'turbo' },
                { name: 'React', logo: 'react', inProgress: true },
                { name: 'TypeScript', logo: 'typescript', inProgress: true },
            ] },
            { label: 'Datenbanken', items: [
                { name: 'MySQL', logo: 'mysql' },
                { name: 'MariaDB', logo: 'mariadb' },
                { name: 'Redis', logo: 'redis' },
            ] },
            { label: 'DevOps & Tools', items: [
                { name: 'Git', logo: 'git' },
                { name: 'GitHub', logo: 'github' },
                { name: 'GitHub Actions', logo: 'githubactions' },
                { name: 'Docker', logo: 'docker' },
                { name: 'DDEV', logo: 'ddev' },
            ] },
        ] %}

        <div class="mt-10 space-y-6">
            {% for category in categories %}
                <div>
                    <h3 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.2em] text-warm-400">{{ category.label }}</h3>
                    <div class="flex flex-wrap gap-2">
                        {% for item in category.items %}
                            <div class="flex items-center gap-2 rounded-lg border {{ item.inProgress is defined and item.inProgress ? 'border-dashed border-warm-300 bg-warm-50' : 'border-warm-200 bg-white' }} px-3 py-1.5">
                                {% if item.logo is defined %}
                                    <img src="{{ asset('images/logos/' ~ item.logo ~ '.' ~ (item.logoExt is defined ? item.logoExt : 'svg')) }}"
                                         alt="{{ item.name }}"
                                         class="h-4 w-4 {{ item.inProgress is defined and item.inProgress ? 'opacity-60' : '' }}"
                                         loading="lazy">
                                {% else %}
                                    <span class="flex h-4 w-4 items-center justify-center rounded text-[9px] font-bold text-white" style="background-color: {{ item.color }}">{{ item.name[:1] }}</span>
                                {% endif %}
                                <span class="text-sm {{ item.inProgress is defined and item.inProgress ? 'text-warm-400' : 'text-warm-700' }}">{{ item.name }}</span>
                                {% if item.inProgress is defined and item.inProgress %}
                                    <span class="text-[10px] italic text-warm-400">in progress</span>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}
