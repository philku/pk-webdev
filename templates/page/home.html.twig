{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
    {# Hero Section — großzügig, editorial #}
    <section class="py-24 sm:py-32">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Fullstack Entwickler
        </p>
        <h1 class="mt-4 font-heading text-5xl leading-tight text-warm-900 sm:text-6xl">
            Philipp Küchau
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-relaxed text-warm-500">
            Ich baue moderne Webanwendungen mit Symfony, Tailwind CSS und Turbo.
            Hier zeige ich, was ich kann.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
            <a href="{{ path('app_demos') }}" class="rounded-lg bg-warm-900 px-6 py-3 text-sm font-medium text-warm-50 transition-all hover:bg-accent-700">
                Tech Demos
            </a>
            <a href="{{ path('app_contact') }}" class="rounded-lg border border-warm-300 px-6 py-3 text-sm font-medium text-warm-700 transition-all hover:border-warm-400 hover:bg-warm-100">
                Kontakt
            </a>
        </div>
    </section>

    {# Trennlinie #}
    <hr class="border-warm-200">

    {# Skills Übersicht #}
    <section class="py-20">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Technologien
        </p>
        <h2 class="mt-3 font-heading text-3xl text-warm-900">Tech Stack</h2>

        <div class="mt-10 grid gap-px overflow-hidden rounded-xl border border-warm-200 bg-warm-200 sm:grid-cols-2 lg:grid-cols-3">
            {% set skills = [
                { name: 'Symfony', description: 'PHP-Framework für robuste Webanwendungen' },
                { name: 'Doctrine ORM', description: 'Datenbank-Abstraction mit Entities & Migrations' },
                { name: 'Twig', description: 'Template Engine für sauberes HTML' },
                { name: 'Tailwind CSS', description: 'Utility-first CSS für modernes Design' },
                { name: 'Turbo', description: 'SPA-Feeling ohne JavaScript-Framework' },
                { name: 'Live Components', description: 'Reaktive UI-Komponenten serverseitig' },
            ] %}

            {% for skill in skills %}
                <div class="bg-warm-50 p-6 transition-colors hover:bg-white">
                    <h3 class="font-medium text-warm-900">{{ skill.name }}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-warm-500">{{ skill.description }}</p>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}
