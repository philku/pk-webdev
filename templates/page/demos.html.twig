{% extends 'base.html.twig' %}

{% block title %}Tech Demos{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Portfolio
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Tech Demos</h1>
        <p class="mt-4 max-w-lg text-warm-500 leading-relaxed">
            Interaktive Mini-Apps, die verschiedene Technologien und Patterns demonstrieren.
        </p>

        <div class="mt-12 grid gap-8 sm:grid-cols-2">
            {# Vereinsplaner Card #}
            <a href="{{ path('app_club_planner') }}" class="group block rounded-xl border border-warm-200 p-7 transition-all hover:border-accent-500 hover:shadow-lg hover:shadow-accent-500/5">
                <h2 class="font-heading text-2xl text-warm-900">Vereinsplaner</h2>
                <p class="mt-3 text-sm leading-relaxed text-warm-500">
                    Mitgliederverwaltung mit CRUD, Live-Suche, Echtzeit-Validierung und Trainingsplaner.
                </p>
                <ul class="mt-5 flex flex-wrap gap-2">
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Doctrine ORM</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Live Components</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Symfony Forms</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Stimulus</li>
                </ul>
            </a>

            {# Metallica Universe Card #}
            <a href="{{ path('app_metallica') }}" class="group block rounded-xl border border-warm-200 p-7 transition-all hover:border-accent-500 hover:shadow-lg hover:shadow-accent-500/5">
                <h2 class="font-heading text-2xl text-warm-900">Metallica Universe</h2>
                <p class="mt-3 text-sm leading-relaxed text-warm-500">
                    Konzert-Weltkarte mit Setlists und Discography Explorer. Daten von setlist.fm und Spotify APIs.
                </p>
                <ul class="mt-5 flex flex-wrap gap-2">
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Spotify API</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">setlist.fm API</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">OAuth 2.0</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Leaflet Maps</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Redis Caching</li>
                </ul>
            </a>

            {# Find my next Co-op Card #}
            <a href="{{ path('app_game_advisor') }}" class="group block rounded-xl border border-warm-200 p-7 transition-all hover:border-accent-500 hover:shadow-lg hover:shadow-accent-500/5">
                <h2 class="font-heading text-2xl text-warm-900">Find my next Co-op</h2>
                <p class="mt-3 text-sm leading-relaxed text-warm-500">
                    KI-gestützter Co-op-Game-Finder. Wähle deine Lieblingsspiele und erhalte personalisierte Vorschläge.
                </p>
                <ul class="mt-5 flex flex-wrap gap-2">
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Gemini API</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">SSE Streaming</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">IGDB API</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">OAuth 2.0</li>
                </ul>
            </a>
        </div>
    </section>
{% endblock %}
