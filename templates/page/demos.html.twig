{% extends 'base.html.twig' %}

{% block title %}Tech Demos{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Portfolio
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Tech Demos</h1>
        <p class="mt-4 max-w-lg text-warm-500 leading-relaxed">
            Interaktive Mini-Apps, die verschiedene Technologien und Patterns demonstrieren.
        </p>

        <div class="mt-12 grid gap-8 sm:grid-cols-2">
            {# Vereinsplaner Card #}
            <article class="group rounded-xl border border-warm-200 p-7 transition-all hover:border-accent-500 hover:shadow-lg hover:shadow-accent-500/5">
                <div class="flex items-start justify-between">
                    <h2 class="font-heading text-2xl text-warm-900">Vereinsplaner</h2>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-warm-500">
                    Mitgliederverwaltung mit CRUD, Live-Suche, Echtzeit-Validierung und sortierbarer Datentabelle.
                </p>
                <ul class="mt-5 flex flex-wrap gap-2">
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Doctrine ORM</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Live Components</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Turbo Frames</li>
                </ul>
                <a href="{{ path('app_club_planner') }}" class="mt-6 inline-block text-sm font-medium text-accent-600 hover:text-accent-700 transition-colors">
                    Demo ansehen &rarr;
                </a>
            </article>

            {# Metallica Universe Card #}
            <article class="group rounded-xl border border-warm-200 p-7 transition-all hover:border-accent-500 hover:shadow-lg hover:shadow-accent-500/5">
                <div class="flex items-start justify-between">
                    <h2 class="font-heading text-2xl text-warm-900">Metallica Universe</h2>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-warm-500">
                    Alle Metallica-Konzerte weltweit auf einer interaktiven Karte mit Setlists. Daten live von der setlist.fm API.
                </p>
                <ul class="mt-5 flex flex-wrap gap-2">
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">HTTP Client</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Caching</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">Leaflet Maps</li>
                    <li class="rounded-full border border-accent-600/20 bg-accent-600/5 px-3 py-1 text-xs font-medium text-accent-700">API-Integration</li>
                </ul>
                <a href="{{ path('app_metallica') }}" class="mt-6 inline-block text-sm font-medium text-accent-600 hover:text-accent-700 transition-colors">
                    Demo ansehen &rarr;
                </a>
            </article>
        </div>
    </section>
{% endblock %}
