{% extends 'base.html.twig' %}

{% block title %}Kontakt{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Kontakt
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Kontakt</h1>
        <p class="mt-4 max-w-lg text-warm-500 leading-relaxed">
            Schreib mir eine Nachricht oder nutze das Kontaktformular.
        </p>

        <div class="mt-12 grid gap-8 max-w-xl">
            {# E-Mail Card #}
            <div class="rounded-xl border border-warm-200 p-7">
                <h2 class="font-heading text-2xl text-warm-900">E-Mail</h2>
                <a href="mailto:p.kuechau@gmx.de"
                   class="mt-5 inline-flex items-center gap-2 rounded-lg bg-accent-600/90 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-accent-600/10 transition-all hover:bg-accent-500/80">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    p.kuechau@gmx.de
                </a>
            </div>

            {# Kontaktformular Card #}
            <div class="rounded-xl border border-warm-200 p-7">
                <h2 class="font-heading text-2xl text-warm-900">Kontaktformular</h2>

                {% for message in app.flashes('success') %}
                    <div class="mt-5 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
                        {{ message }}
                    </div>
                {% endfor %}

                {{ form_start(form, {'attr': {'class': 'mt-5 space-y-4'}}) }}

                {# Name #}
                <div>
                    {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-medium text-warm-700'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'mt-1 block w-full rounded-lg border border-warm-200 bg-white px-4 py-2.5 text-sm text-warm-900 placeholder-warm-400 outline-none transition focus:border-accent-500 focus:ring-1 focus:ring-accent-500'}}) }}
                    {% for error in form.name.vars.errors %}
                        <p class="mt-1 text-xs text-red-600">{{ error.message }}</p>
                    {% endfor %}
                </div>

                {# E-Mail #}
                <div>
                    {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-warm-700'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'mt-1 block w-full rounded-lg border border-warm-200 bg-white px-4 py-2.5 text-sm text-warm-900 placeholder-warm-400 outline-none transition focus:border-accent-500 focus:ring-1 focus:ring-accent-500'}}) }}
                    {% for error in form.email.vars.errors %}
                        <p class="mt-1 text-xs text-red-600">{{ error.message }}</p>
                    {% endfor %}
                </div>

                {# Honeypot #}
                <div class="absolute opacity-0 -z-10 h-0 overflow-hidden">
                    {{ form_widget(form.website) }}
                </div>

                {# Nachricht #}
                <div>
                    {{ form_label(form.message, null, {'label_attr': {'class': 'block text-sm font-medium text-warm-700'}}) }}
                    {{ form_widget(form.message, {'attr': {'class': 'mt-1 block w-full rounded-lg border border-warm-200 bg-white px-4 py-2.5 text-sm text-warm-900 placeholder-warm-400 outline-none transition focus:border-accent-500 focus:ring-1 focus:ring-accent-500', 'rows': '5'}}) }}
                    {% for error in form.message.vars.errors %}
                        <p class="mt-1 text-xs text-red-600">{{ error.message }}</p>
                    {% endfor %}
                </div>

                {# Submit #}
                <button type="submit"
                        class="cursor-pointer inline-flex items-center gap-2 rounded-lg bg-accent-600/90 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-accent-600/10 transition-all hover:bg-accent-500/80">
                    Nachricht abschicken
                </button>

                {{ form_end(form) }}
            </div>
        </div>
    </section>
{% endblock %}
