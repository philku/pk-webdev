<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Philipp Küchau — Fullstack Entwickler{% endblock %} | philku.de</title>
        <meta name="description" content="{% block meta_description %}Philipp Küchau — Fullstack Entwickler aus Berlin. Symfony, PHP, Tailwind CSS, React. Portfolio und Tech-Demos.{% endblock %}">
        <meta name="author" content="Philipp Küchau">
        <meta property="og:title" content="{% block og_title %}Philipp Küchau | Fullstack Entwickler{% endblock %}">
        <meta property="og:description" content="{% block og_description %}Fullstack Entwickler aus Berlin — Symfony, PHP, Tailwind CSS, React.{% endblock %}">
        <meta property="og:type" content="website">
        <meta property="og:locale" content="de_DE">
        <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">

        {# Fonts: Sora (Headlines) + DM Sans (Body) — self-hosted, GDPR-compliant #}

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-warm-50 text-warm-800 antialiased">

        {# ========== NAVIGATION ========== #}
        <header class="sticky top-0 z-50 border-b border-warm-200 bg-warm-50/80 backdrop-blur-md" data-controller="mobile-menu">
            <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-5">
                {# Logo / Name #}
                <a href="{{ path('app_home') }}" class="font-heading text-xl font-black text-warm-900 transition-colors hover:text-accent-600">
                    PK.
                </a>

                {# Desktop Navigation — active route gets text-warm-900 #}
                {% set current_route = app.request.attributes.get('_route') %}
                <ul class="hidden items-center gap-8 md:flex">
                    <li><a href="{{ path('app_home') }}" class="nav-link text-sm transition-colors hover:text-warm-900 {{ current_route == 'app_home' ? 'text-warm-900' : 'text-warm-500' }}">Home</a></li>
                    <li><a href="{{ path('app_demos') }}" class="nav-link text-sm transition-colors hover:text-warm-900 {{ current_route starts with 'app_demos' or current_route starts with 'app_club' or current_route starts with 'app_metallica' or current_route starts with 'app_game' or current_route starts with 'app_nhl' or current_route starts with 'app_training' ? 'text-warm-900' : 'text-warm-500' }}">Tech Demos</a></li>
                </ul>

                {# Mobile hamburger — 3 spans animate into an X via 'open' class #}
                <button
                    type="button"
                    class="group relative h-5 w-5 rounded-md text-warm-500 transition-colors hover:text-warm-900 md:hidden"
                    data-action="click->mobile-menu#toggle"
                    data-mobile-menu-target="button"
                >
                    <span class="absolute left-0 top-0.5 h-0.5 w-5 rounded-full bg-current transition-all duration-200 group-[.open]:top-[9px] group-[.open]:rotate-45"></span>
                    <span class="absolute left-0 top-[9px] h-0.5 w-5 rounded-full bg-current transition-opacity duration-200 group-[.open]:opacity-0"></span>
                    <span class="absolute left-0 bottom-0.5 h-0.5 w-5 rounded-full bg-current transition-all duration-200 group-[.open]:bottom-[9px] group-[.open]:-rotate-45"></span>
                </button>
            </nav>

            {# Mobile nav — absolute overlay, full width #}
            <div class="hidden absolute left-0 right-0 border-t border-warm-200 bg-warm-50 shadow-lg md:hidden" data-mobile-menu-target="menu">
                <ul class="space-y-1 px-6 py-4">
                    <li><a href="{{ path('app_home') }}" data-action="click->mobile-menu#close" class="block rounded-md px-3 py-2 text-sm hover:bg-warm-100 hover:text-warm-900 {{ current_route == 'app_home' ? 'text-warm-900 font-medium' : 'text-warm-500' }}">Home</a></li>
                    <li><a href="{{ path('app_demos') }}" data-action="click->mobile-menu#close" class="block rounded-md px-3 py-2 text-sm hover:bg-warm-100 hover:text-warm-900 {{ current_route starts with 'app_demos' or current_route starts with 'app_club' or current_route starts with 'app_metallica' or current_route starts with 'app_game' or current_route starts with 'app_nhl' or current_route starts with 'app_training' ? 'text-warm-900 font-medium' : 'text-warm-500' }}">Tech Demos</a></li>
                </ul>
            </div>
        </header>

        {# ========== MAIN CONTENT ========== #}
        <main class="mx-auto max-w-4xl px-6 py-20">
            {% block body %}{% endblock %}
        </main>

        {# ========== FOOTER ========== #}
        <footer class="border-t border-warm-200">
            <div class="mx-auto max-w-4xl px-6 py-10">
                <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
                    <p class="text-sm text-warm-400">
                        &copy; {{ 'now'|date('Y') }} Philipp Küchau
                    </p>
                    <div class="flex items-center gap-4 text-sm text-warm-400">
                        <a href="{{ path('app_impressum') }}" class="transition-colors hover:text-warm-600">Impressum</a>
                        <span>&middot;</span>
                        <a href="{{ path('app_datenschutz') }}" class="transition-colors hover:text-warm-600">Datenschutz</a>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
