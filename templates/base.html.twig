<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Philipp Kuchau{% endblock %} | Webentwicklung</title>

        {# Fonts: Sora (Headlines) + DM Sans (Body) — self-hosted, DSGVO-konform #}

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-warm-50 text-warm-800 antialiased">

        {# ========== NAVIGATION ========== #}
        <header class="sticky top-0 z-50 border-b border-warm-200 bg-warm-50/80 backdrop-blur-md" data-controller="mobile-menu">
            <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-5">
                {# Logo / Name — Serif-Font für Wiedererkennungswert #}
                <a href="{{ path('app_home') }}" class="font-heading text-xl text-warm-900 transition-colors hover:text-accent-600">
                    PK
                </a>

                {# Desktop Navigation #}
                <ul class="hidden items-center gap-8 md:flex">
                    <li><a href="{{ path('app_home') }}" class="nav-link text-sm text-warm-500 transition-colors hover:text-warm-900">Home</a></li>
                    <li><a href="{{ path('app_about') }}" class="nav-link text-sm text-warm-500 transition-colors hover:text-warm-900">Über mich</a></li>
                    <li><a href="{{ path('app_demos') }}" class="nav-link text-sm text-warm-500 transition-colors hover:text-warm-900">Tech Demos</a></li>
                    <li><a href="{{ path('app_contact') }}" class="nav-link text-sm text-warm-500 transition-colors hover:text-warm-900">Kontakt</a></li>
                </ul>

                {# Mobile Hamburger Button — 3 Spans die sich zum X animieren.
                   Jeder Span ist ein Strich. Beim Öffnen:
                   - Oben: dreht sich 45° und rutscht zur Mitte
                   - Mitte: wird unsichtbar (opacity 0)
                   - Unten: dreht sich -45° und rutscht zur Mitte
                   Der Controller toggled die Klasse 'open' auf dem Button. #}
                <button
                    type="button"
                    class="group relative h-5 w-5 rounded-md text-warm-500 transition-colors hover:text-warm-900 md:hidden"
                    data-action="click->mobile-menu#toggle"
                    data-mobile-menu-target="button"
                >
                    <span class="absolute left-0 top-0.5 h-0.5 w-5 rounded-full bg-current transition-all duration-200 group-[.open]:top-[9px] group-[.open]:rotate-45"></span>
                    <span class="absolute left-0 top-[9px] h-0.5 w-5 rounded-full bg-current transition-opacity duration-200 group-[.open]:opacity-0"></span>
                    <span class="absolute left-0 bottom-0.5 h-0.5 w-5 rounded-full bg-current transition-all duration-200 group-[.open]:bottom-[9px] group-[.open]:-rotate-45"></span>
                </button>
            </nav>

            {# Mobile Navigation — absolute damit es über dem Content schwebt statt ihn runterzuschieben.
               left-0 right-0: volle Breite. bg-warm-50 + shadow: saubere Abgrenzung zum Content. #}
            <div class="hidden absolute left-0 right-0 border-t border-warm-200 bg-warm-50 shadow-lg md:hidden" data-mobile-menu-target="menu">
                <ul class="space-y-1 px-6 py-4">
                    <li><a href="{{ path('app_home') }}" data-action="click->mobile-menu#close" class="block rounded-md px-3 py-2 text-sm text-warm-500 hover:bg-warm-100 hover:text-warm-900">Home</a></li>
                    <li><a href="{{ path('app_about') }}" data-action="click->mobile-menu#close" class="block rounded-md px-3 py-2 text-sm text-warm-500 hover:bg-warm-100 hover:text-warm-900">Über mich</a></li>
                    <li><a href="{{ path('app_demos') }}" data-action="click->mobile-menu#close" class="block rounded-md px-3 py-2 text-sm text-warm-500 hover:bg-warm-100 hover:text-warm-900">Tech Demos</a></li>
                    <li><a href="{{ path('app_contact') }}" data-action="click->mobile-menu#close" class="block rounded-md px-3 py-2 text-sm text-warm-500 hover:bg-warm-100 hover:text-warm-900">Kontakt</a></li>
                </ul>
            </div>
        </header>

        {# ========== HAUPTINHALT ========== #}
        <main class="mx-auto max-w-4xl px-6 py-20">
            {% block body %}{% endblock %}
        </main>

        {# ========== FOOTER ========== #}
        <footer class="border-t border-warm-200">
            <div class="mx-auto max-w-4xl px-6 py-10">
                <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
                    <p class="text-sm text-warm-400">
                        &copy; {{ 'now'|date('Y') }} Philipp Kuchau
                    </p>
                    <p class="text-sm text-warm-400">
                        Symfony &middot; Tailwind CSS &middot; Turbo
                    </p>
                </div>
            </div>
        </footer>
    </body>
</html>
