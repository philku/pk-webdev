{% extends 'base.html.twig' %}

{% block title %}Vereinsplaner{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Tech Demo
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Vereinsplaner</h1>
        <p class="mt-4 max-w-lg text-warm-500 leading-relaxed">
            Mitgliederverwaltung mit CRUD, Live-Suche und Echtzeit-Validierung.
        </p>
        {# Flash Messages — erscheinen nach Erstellen/Bearbeiten/Löschen #}
        {% for message in app.flashes('success') %}
            <div class="mt-6 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
                {{ message }}
            </div>
        {% endfor %}

        <div class="mt-8">
            <a href="{{ path('app_club_planner_new') }}" class="inline-block rounded-lg bg-warm-900 px-5 py-2.5 text-sm font-medium text-warm-50 transition-colors hover:bg-accent-700">
                + Neues Mitglied
            </a>
        </div>
    </section>

    {# Mitgliedertabelle #}
    <section class="py-8">
        <div class="overflow-hidden rounded-xl border border-warm-200">
            <table class="w-full text-left text-sm">
                {# Tabellenkopf #}
                <thead class="border-b border-warm-200 bg-warm-100">
                    <tr>
                        <th class="px-6 py-3 font-medium text-warm-600">Name</th>
                        <th class="hidden px-6 py-3 font-medium text-warm-600 sm:table-cell">Email</th>
                        <th class="hidden px-6 py-3 font-medium text-warm-600 md:table-cell">Team</th>
                        <th class="px-6 py-3 font-medium text-warm-600">Position</th>
                        <th class="px-6 py-3 font-medium text-warm-600">Rolle</th>
                        <th class="px-6 py-3 font-medium text-warm-600 text-right">Aktionen</th>
                    </tr>
                </thead>

                {# Tabelleninhalt — hier iterieren wir über die Members aus der DB #}
                <tbody class="divide-y divide-warm-200">
                    {# for-Schleife in Twig: wie foreach in PHP #}
                    {% for member in members %}
                        <tr class="transition-colors hover:bg-warm-50">
                            <td class="px-6 py-4 font-medium text-warm-900">
                                {{ member.name }}
                            </td>
                            <td class="hidden px-6 py-4 text-warm-500 sm:table-cell">
                                {{ member.email }}
                            </td>
                            <td class="hidden px-6 py-4 text-warm-500 md:table-cell">
                                {# member.team greift auf das Team-OBJEKT zu,
                                   .name holt den Namen davon — die Relation funktioniert einfach so! #}
                                {{ member.team.name }}
                            </td>
                            <td class="px-6 py-4 text-warm-500">
                                {{ member.position ?? '—' }}
                            </td>
                            <td class="px-6 py-4">
                                {# Rolle als farbiges Badge #}
                                <span class="inline-block rounded-full px-2.5 py-0.5 text-xs font-medium
                                    {% if member.role == 'Trainer' %}
                                        bg-amber-50 text-amber-700 border border-amber-200
                                    {% elseif member.role == 'Betreuer' %}
                                        bg-purple-50 text-purple-700 border border-purple-200
                                    {% else %}
                                        bg-accent-600/5 text-accent-700 border border-accent-600/20
                                    {% endif %}
                                ">
                                    {{ member.role }}
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a href="{{ path('app_club_planner_edit', { id: member.id }) }}" class="text-sm text-warm-500 hover:text-accent-600 transition-colors">
                                        Bearbeiten
                                    </a>
                                    {# Löschen mit eigenem Bestätigungs-Modal #}
                                    <div data-controller="confirm">
                                        <button type="button" data-action="click->confirm#show" class="text-sm text-warm-400 hover:text-red-600 transition-colors">
                                            Löschen
                                        </button>

                                        <dialog data-confirm-target="dialog" class="rounded-xl border border-warm-200 bg-white p-0 shadow-xl backdrop:bg-warm-900/40 backdrop:backdrop-blur-sm">
                                            <div class="p-6">
                                                <h3 class="font-heading text-lg text-warm-900">Mitglied löschen?</h3>
                                                <p class="mt-2 text-sm text-warm-500">
                                                    <strong>{{ member.name }}</strong> wird unwiderruflich gelöscht.
                                                </p>
                                                <div class="mt-6 flex items-center justify-end gap-3">
                                                    <button type="button" data-action="click->confirm#close" class="rounded-lg border border-warm-300 px-4 py-2 text-sm font-medium text-warm-700 transition-colors hover:bg-warm-100">
                                                        Abbrechen
                                                    </button>
                                                    <form method="post" action="{{ path('app_club_planner_delete', { id: member.id }) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ member.id) }}">
                                                        <button type="submit" class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-700">
                                                            Löschen
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </dialog>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Info-Zeile unter der Tabelle #}
        <p class="mt-4 text-sm text-warm-400">
            {{ members|length }} Mitglieder in {{ teams|length }} Teams
        </p>
    </section>
{% endblock %}
