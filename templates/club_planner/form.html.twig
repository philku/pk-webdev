{% extends 'base.html.twig' %}

{% block title %}{{ title }} — Vereinsplaner{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Vereinsplaner
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">{{ title }}</h1>

        <div class="mt-10 max-w-xl">
            {# form_start() erzeugt das <form>-Tag mit der richtigen action-URL und method #}
            {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

                {% for field in form %}
                    {# Versteckte Felder (wie CSRF-Token) überspringen #}
                    {% if field.vars.name != '_token' %}
                        <div>
                            {# Label #}
                            {{ form_label(field, null, { label_attr: {
                                class: 'block text-sm font-medium text-warm-700 mb-1'
                            } }) }}

                            {# Eingabefeld #}
                            {{ form_widget(field, { attr: {
                                class: 'w-full rounded-lg border border-warm-300 bg-white px-4 py-2.5 text-sm text-warm-900 placeholder-warm-400 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500'
                            } }) }}

                            {# Fehlermeldungen (z.B. "Bitte einen Namen eingeben.") #}
                            {{ form_errors(field, { attr: {
                                class: 'mt-1 text-sm text-red-600'
                            } }) }}
                        </div>
                    {% endif %}
                {% endfor %}

                {# Buttons #}
                <div class="flex items-center gap-4 pt-4">
                    <button type="submit" class="rounded-lg bg-warm-900 px-6 py-2.5 text-sm font-medium text-warm-50 transition-colors hover:bg-accent-700">
                        Speichern
                    </button>
                    <a href="{{ path('app_club_planner') }}" class="text-sm text-warm-500 hover:text-warm-700 transition-colors">
                        Abbrechen
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
