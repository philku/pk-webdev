{% extends 'base.html.twig' %}

{% block title %}{{ title }} — Vereinsplaner{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Vereinsplaner
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">{{ title }}</h1>

        <div class="mt-10 max-w-xl">
            {# Hier wird die Live Component eingebunden. #}
            {# "MemberForm" = der Name der PHP-Klasse (ohne Namespace). #}
            {# initialFormData = das Member-Objekt (leer bei "neu", befüllt bei "bearbeiten"). #}
            {# form = das vorbereitete FormView-Objekt vom Controller. #}
            {{ component('MemberForm', {
                initialFormData: member,
                form: form
            }) }}
        </div>
    </section>
{% endblock %}
