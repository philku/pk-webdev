{% extends 'base.html.twig' %}

{% block title %}Anwesenheit — {{ training.scheduledAt|date('d.m.Y') }}{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            {{ training.team.name }}
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Anwesenheit erfassen</h1>
        <p class="mt-2 text-warm-500">
            {{ training.scheduledAt|date('d.m.Y') }} um {{ training.scheduledAt|date('H:i') }} Uhr
            {% if training.description %} · {{ training.description }}{% endif %}
            {% if training.location %} · {{ training.location }}{% endif %}
        </p>

        {# Flash Messages #}
        {% for message in app.flashes('success') %}
            <div class="mt-6 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
                {{ message }}
            </div>
        {% endfor %}
    </section>

    <section class="py-8">
        {# Manuelles HTML-Formular statt Symfony CollectionType.
           Jedes Select hat name="status[{memberId}]" — im Controller
           kommt das als Array an: $request->request->all('status').
           Einfacher und transparenter als CollectionType. #}
        <form method="post" action="{{ path('app_training_attendance', { id: training.id }) }}">

            {# ========== MOBILE: Card-Layout (unter lg) ========== #}
            <div class="space-y-3 lg:hidden">
                {% for attendance in attendances %}
                    <div class="rounded-xl border border-warm-200 p-4 flex items-center justify-between">
                        <div>
                            <p class="font-medium text-warm-900">{{ attendance.member.name }}</p>
                            <p class="text-sm text-warm-400">{{ attendance.member.role }}</p>
                        </div>
                        <select
                            name="status[{{ attendance.member.id }}]"
                            class="rounded-lg border border-warm-300 bg-white px-3 py-1.5 text-sm text-warm-700 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
                        >
                            <option value="anwesend" {{ attendance.status == 'anwesend' ? 'selected' }}>Anwesend</option>
                            <option value="abwesend" {{ attendance.status == 'abwesend' ? 'selected' }}>Abwesend</option>
                            <option value="entschuldigt" {{ attendance.status == 'entschuldigt' ? 'selected' }}>Entschuldigt</option>
                        </select>
                    </div>
                {% endfor %}
            </div>

            {# ========== DESKTOP: Tabelle (ab lg) ========== #}
            <div class="hidden lg:block">
                <div class="overflow-hidden rounded-xl border border-warm-200">
                    <table class="w-full text-left text-sm">
                        <thead class="border-b border-warm-200 bg-warm-100">
                            <tr>
                                <th class="px-6 py-3 font-medium text-warm-600">Name</th>
                                <th class="px-6 py-3 font-medium text-warm-600">Rolle</th>
                                <th class="px-6 py-3 font-medium text-warm-600">Position</th>
                                <th class="px-6 py-3 font-medium text-warm-600">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-warm-200">
                            {% for attendance in attendances %}
                                <tr class="transition-colors hover:bg-warm-50">
                                    <td class="px-6 py-4 font-medium text-warm-900">{{ attendance.member.name }}</td>
                                    <td class="px-6 py-4 text-warm-500">{{ attendance.member.role }}</td>
                                    <td class="px-6 py-4 text-warm-500">{{ attendance.member.position ?? '—' }}</td>
                                    <td class="px-6 py-4">
                                        <select
                                            name="status[{{ attendance.member.id }}]"
                                            class="rounded-lg border border-warm-300 bg-white px-3 py-1.5 text-sm text-warm-700 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
                                        >
                                            <option value="anwesend" {{ attendance.status == 'anwesend' ? 'selected' }}>Anwesend</option>
                                            <option value="abwesend" {{ attendance.status == 'abwesend' ? 'selected' }}>Abwesend</option>
                                            <option value="entschuldigt" {{ attendance.status == 'entschuldigt' ? 'selected' }}>Entschuldigt</option>
                                        </select>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="px-6 py-8 text-center text-sm text-warm-400 italic">
                                        Keine Mitglieder in diesem Team.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-6 flex items-center gap-4">
                <button type="submit" class="rounded-lg bg-warm-900 px-5 py-2.5 text-sm font-medium text-warm-50 transition-colors hover:bg-accent-700">
                    Speichern
                </button>
                <a href="{{ path('app_trainings') }}" class="text-sm text-warm-500 hover:text-warm-700 transition-colors">
                    Zurück
                </a>
            </div>
        </form>
    </section>
{% endblock %}
