{% extends 'base.html.twig' %}

{% block title %}Trainingsquote — {{ team.name }}{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            {{ team.name }}
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">Trainingsquote</h1>
        <p class="mt-2 text-warm-500">
            Anwesenheitsquote pro Mitglied über alle Trainings.
        </p>

        <div class="mt-6">
            <a href="{{ path('app_trainings') }}" class="inline-flex items-center gap-1.5 rounded-lg border border-warm-200 px-3.5 py-2 text-sm font-medium text-warm-600 transition-colors hover:border-accent-600 hover:text-accent-600">
                &larr; Zurück zum Trainingsplaner
            </a>
        </div>
    </section>

    <section class="py-8">
        {% if stats|length > 0 %}
            {# ========== MOBILE: Card-Layout (unter lg) ========== #}
            <div class="space-y-4 lg:hidden">
                {% for stat in stats %}
                    {# Percentage calc in Twig — DQL can't round cleanly #}
                    {% set percent = stat.totalTrainings > 0 ? (stat.presentCount / stat.totalTrainings * 100) : 0 %}

                    <div class="rounded-xl border border-warm-200 p-5">
                        <div class="flex items-center justify-between">
                            <p class="font-medium text-warm-900">{{ stat.memberName }}</p>
                            <span class="text-sm font-medium
                                {% if percent >= 80 %}text-green-600
                                {% elseif percent >= 50 %}text-amber-600
                                {% else %}text-red-600{% endif %}
                            ">
                                {{ percent|number_format(0) }}%
                            </span>
                        </div>
                        <p class="mt-1 text-sm text-warm-400">
                            {{ stat.presentCount }}/{{ stat.totalTrainings }} Trainings
                        </p>
                        {# Progress bar — width = percent, color by attendance rate #}
                        <div class="mt-3 h-2 w-full rounded-full bg-warm-100">
                            <div
                                class="h-2 rounded-full transition-all
                                    {% if percent >= 80 %}bg-green-500
                                    {% elseif percent >= 50 %}bg-amber-500
                                    {% else %}bg-red-500{% endif %}"
                                style="width: {{ percent }}%"
                            ></div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# ========== DESKTOP: Tabelle (ab lg) ========== #}
            <div class="hidden lg:block">
                <div class="overflow-hidden rounded-xl border border-warm-200">
                    <table class="w-full text-left text-sm">
                        <thead class="border-b border-warm-200 bg-warm-100">
                            <tr>
                                <th class="px-6 py-3 font-medium text-warm-600">Name</th>
                                <th class="px-6 py-3 font-medium text-warm-600">Anwesend</th>
                                <th class="px-6 py-3 font-medium text-warm-600">Trainings</th>
                                <th class="px-6 py-3 font-medium text-warm-600 w-1/3">Quote</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-warm-200">
                            {% for stat in stats %}
                                {% set percent = stat.totalTrainings > 0 ? (stat.presentCount / stat.totalTrainings * 100) : 0 %}
                                <tr class="transition-colors hover:bg-warm-50">
                                    <td class="px-6 py-4 font-medium text-warm-900">{{ stat.memberName }}</td>
                                    <td class="px-6 py-4 text-warm-500">{{ stat.presentCount }}</td>
                                    <td class="px-6 py-4 text-warm-500">{{ stat.totalTrainings }}</td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            {# Progress bar #}
                                            <div class="h-2 flex-1 rounded-full bg-warm-100">
                                                <div
                                                    class="h-2 rounded-full transition-all
                                                        {% if percent >= 80 %}bg-green-500
                                                        {% elseif percent >= 50 %}bg-amber-500
                                                        {% else %}bg-red-500{% endif %}"
                                                    style="width: {{ percent }}%"
                                                ></div>
                                            </div>
                                            {# Percentage value #}
                                            <span class="w-12 text-right text-sm font-medium
                                                {% if percent >= 80 %}text-green-600
                                                {% elseif percent >= 50 %}text-amber-600
                                                {% else %}text-red-600{% endif %}
                                            ">
                                                {{ percent|number_format(0) }}%
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% else %}
            <p class="text-sm text-warm-400 italic">Noch keine Trainings für dieses Team.</p>
        {% endif %}
    </section>
{% endblock %}
