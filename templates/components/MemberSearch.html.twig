{# Live Component for search, sorting, and pagination #}
<div {{ attributes }}>

    {# Search field — debounce(300) waits 300ms after last keystroke before sending request #}
    <div class="relative">
        <input
            type="search"
            data-model="debounce(300)|query"
            placeholder="Mitglieder suchen (Name, E-Mail, Team, Rolle)..."
            value="{{ query }}"
            class="w-full rounded-lg border border-warm-300 bg-white py-2.5 pl-10 pr-4 text-sm text-warm-900 placeholder-warm-400 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        >
        {# Search icon #}
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-warm-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
    </div>

    {# --- Result counter --- #}
    {% set members = this.members %}
    {% set total = this.total %}
    {% set lastPage = this.lastPage %}
    <p class="mt-4 text-sm text-warm-400">
        {{ total }} Mitglied{{ total != 1 ? 'er' : '' }}
        {% if query is not empty %}
            fuer &bdquo;{{ query }}&ldquo;
        {% endif %}
        {% if lastPage > 1 %}
            &middot; Seite {{ page }} von {{ lastPage }}
        {% endif %}
    </p>

    {# Sort icon macro for table headers #}
    {% macro sort_icon(field, currentSort, currentDirection) %}
        {% if currentSort == field %}
            {# Active column: arrow shows current direction #}
            {% if currentDirection == 'ASC' %}
                <svg class="ml-1 inline h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" /></svg>
            {% else %}
                <svg class="ml-1 inline h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            {% endif %}
        {% else %}
            {# Inactive column: subtle double arrow #}
            <svg class="ml-1 inline h-3 w-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" /></svg>
        {% endif %}
    {% endmacro %}

    {# ========== MOBILE: Card layout (visible below lg) ========== #}
    <div class="mt-4 space-y-4 lg:hidden">
        {# Mobile sort buttons #}
        <div class="flex flex-wrap gap-2">
            {% for field, label in { name: 'Name', team: 'Team', role: 'Rolle' } %}
                <button
                    type="button"
                    data-action="live#action"
                    data-live-action-param="sort"
                    data-live-field-param="{{ field }}"
                    class="rounded-full border px-3 py-1 text-xs font-medium transition-colors
                        {{ sortBy == field
                            ? 'border-accent-500 bg-accent-50 text-accent-700'
                            : 'border-warm-300 text-warm-500 hover:border-warm-400' }}"
                >
                    {{ label }}
                    {{ _self.sort_icon(field, sortBy, sortDirection) }}
                </button>
            {% endfor %}
        </div>

        {% for member in members %}
            <div class="rounded-xl border border-warm-200 p-5">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-medium text-warm-900">{{ member.name }}</p>
                        <p class="mt-1 text-sm text-warm-500">{{ member.email }}</p>
                    </div>
                    <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                        {% if member.role == 'Trainer' %}
                            bg-amber-50 text-amber-700 border border-amber-200
                        {% elseif member.role == 'Betreuer' %}
                            bg-purple-50 text-purple-700 border border-purple-200
                        {% else %}
                            bg-accent-600/5 text-accent-700 border border-accent-600/20
                        {% endif %}
                    ">
                        {{ member.role }}
                    </span>
                </div>

                <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-sm text-warm-400">
                    <span>{{ member.team.name }}</span>
                    {% if member.position %}
                        <span>&middot; {{ member.position }}</span>
                    {% endif %}
                    {% if member.phone %}
                        <span>&middot; {{ member.phone }}</span>
                    {% endif %}
                </div>

                <div class="mt-4 flex items-center gap-4 border-t border-warm-100 pt-3">
                    <a href="{{ path('app_club_planner_edit', { id: member.id }) }}" class="text-sm text-warm-500 hover:text-accent-600 transition-colors">
                        Bearbeiten
                    </a>
                    <div data-controller="confirm">
                        <button type="button" data-action="click->confirm#show" class="text-sm text-warm-400 hover:text-red-600 transition-colors">
                            Löschen
                        </button>
                        <dialog data-confirm-target="dialog" class="rounded-xl border border-warm-200 bg-white p-0 shadow-xl backdrop:bg-warm-900/40 backdrop:backdrop-blur-sm">
                            <div class="p-6 text-left">
                                <h3 class="font-heading text-lg text-warm-900">Mitglied löschen?</h3>
                                <p class="mt-2 text-sm text-warm-500">
                                    <strong>{{ member.name }}</strong> wird unwiderruflich gelöscht.
                                </p>
                                <div class="mt-6 flex items-center justify-start gap-3">
                                    <button type="button" data-action="click->confirm#close" class="rounded-lg border border-warm-300 px-4 py-2 text-sm font-medium text-warm-700 transition-colors hover:bg-warm-100">
                                        Abbrechen
                                    </button>
                                    <form method="post" action="{{ path('app_club_planner_delete', { id: member.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ member.id) }}">
                                        <button type="submit" class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-700">
                                            Löschen
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </dialog>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-sm text-warm-400 italic">Keine Mitglieder gefunden.</p>
        {% endfor %}
    </div>

    {# ========== DESKTOP: Table (visible from lg) ========== #}
    <div class="mt-4 hidden lg:block">
        <div class="overflow-hidden rounded-xl border border-warm-200">
            <table class="w-full text-left text-sm">
                <thead class="border-b border-warm-200 bg-warm-100">
                    <tr>
                        {# Sortable column headers — calls sort() on server via Live Component #}
                        {% for field, label in { name: 'Name', email: 'Email', team: 'Team', role: 'Rolle' } %}
                            <th class="px-6 py-3 font-medium text-warm-600">
                                <button
                                    type="button"
                                    data-action="live#action"
                                    data-live-action-param="sort"
                    data-live-field-param="{{ field }}"
                                    class="inline-flex items-center transition-colors hover:text-warm-900"
                                >
                                    {{ label }}
                                    {{ _self.sort_icon(field, sortBy, sortDirection) }}
                                </button>
                            </th>
                        {% endfor %}
                        {# Position is not sortable (often empty) #}
                        <th class="px-6 py-3 font-medium text-warm-600">Position</th>
                        <th class="px-6 py-3 font-medium text-warm-600 text-right">Aktionen</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-warm-200">
                    {% for member in members %}
                        <tr class="transition-colors hover:bg-warm-50">
                            <td class="px-6 py-4 font-medium text-warm-900">{{ member.name }}</td>
                            <td class="px-6 py-4 text-warm-500">{{ member.email }}</td>
                            <td class="px-6 py-4 text-warm-500">{{ member.team.name }}</td>
                            <td class="px-6 py-4">
                                <span class="inline-block rounded-full px-2.5 py-0.5 text-xs font-medium
                                    {% if member.role == 'Trainer' %}
                                        bg-amber-50 text-amber-700 border border-amber-200
                                    {% elseif member.role == 'Betreuer' %}
                                        bg-purple-50 text-purple-700 border border-purple-200
                                    {% elseif member.role == 'Mitglied' %}
                                        bg-blue-50 text-blue-700 border border-blue-200
                                    {% else %}
                                    bg-accent-600/5 text-accent-700 border border-accent-600/20
                                    {% endif %}
                                ">
                                    {{ member.role }}
                                </span>
                            </td>
                            <td class="px-6 py-4 text-warm-500">{{ member.position ?? '—' }}</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a href="{{ path('app_club_planner_edit', { id: member.id }) }}" class="text-sm text-warm-500 hover:text-accent-600 transition-colors">
                                        Bearbeiten
                                    </a>
                                    <div data-controller="confirm">
                                        <button type="button" data-action="click->confirm#show" class="cursor-pointer text-sm text-warm-400 hover:text-red-600 transition-colors">
                                            Löschen
                                        </button>
                                        <dialog data-confirm-target="dialog" class="rounded-xl border border-warm-200 bg-white p-0 shadow-xl backdrop:bg-warm-900/40 backdrop:backdrop-blur-sm">
                                            <div class="p-6 text-left">
                                                <h3 class="font-heading text-lg text-warm-900">Mitglied löschen?</h3>
                                                <p class="mt-2 text-sm text-warm-500">
                                                    <strong>{{ member.name }}</strong> wird unwiderruflich gelöscht.
                                                </p>
                                                <div class="mt-6 flex items-center justify-start gap-3">
                                                    <button type="button" data-action="click->confirm#close" class="cursor-pointer rounded-lg border border-warm-300 px-4 py-2 text-sm font-medium text-warm-700 transition-colors hover:bg-warm-100">
                                                        Abbrechen
                                                    </button>
                                                    <form method="post" action="{{ path('app_club_planner_delete', { id: member.id }) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ member.id) }}">
                                                        <button type="submit" class="cursor-pointer rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-700">
                                                            Löschen
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </dialog>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-sm text-warm-400 italic">
                                Keine Mitglieder gefunden.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ========== PAGINATION ========== #}
    {% if lastPage > 1 %}
        <nav class="mt-6 flex items-center justify-between">
            {# Previous button #}
            {% if page > 1 %}
                <button
                    type="button"
                    data-action="live#action"
                    data-live-action-param="goToPage"
                    data-live-page-param="{{ page - 1 }}"
                    class="cursor-pointer rounded-lg border border-warm-300 px-4 py-2 text-sm font-medium text-warm-700 transition-colors hover:bg-warm-100"
                >
                    &larr; Zurück
                </button>
            {% else %}
                {# Disabled button on page 1 #}
                <span class="rounded-lg border border-warm-200 px-4 py-2 text-sm font-medium text-warm-300">
                    &larr; Zurück
                </span>
            {% endif %}

            {# Page numbers #}
            <div class="flex gap-1">
                {% for p in 1..lastPage %}
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="goToPage"
                        data-live-page-param="{{ p }}"
                        class="cursor-pointer rounded-lg px-3 py-1.5 text-sm font-medium transition-colors
                            {{ p == page
                                ? 'bg-warm-900 text-warm-50'
                                : 'text-warm-500 hover:bg-warm-100 hover:text-warm-900' }}"
                    >
                        {{ p }}
                    </button>
                {% endfor %}
            </div>

            {# Next button #}
            {% if page < lastPage %}
                <button
                    type="button"
                    data-action="live#action"
                    data-live-action-param="goToPage"
                    data-live-page-param="{{ page + 1 }}"
                    class="cursor-pointer rounded-lg border border-warm-300 px-4 py-2 text-sm font-medium text-warm-700 transition-colors hover:bg-warm-100"
                >
                    Weiter &rarr;
                </button>
            {% else %}
                <span class="rounded-lg border border-warm-200 px-4 py-2 text-sm font-medium text-warm-300">
                    Weiter &rarr;
                </span>
            {% endif %}
        </nav>
    {% endif %}
</div>
