{# Live Component template for MemberForm #}
<div {{ attributes }}>

    {# Live validation on every change event via ComponentWithFormTrait #}
    {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

        {% for field in form %}
            {# Skip hidden fields (e.g. CSRF token) #}
            {% if field.vars.name != '_token' %}
                <div>
                    {# Label  #}
                    {{ form_label(field, null, { label_attr: {
                        class: 'block text-sm font-medium text-warm-700 mb-1'
                    } }) }}

                    {# Input — border color changes on validation error #}
                    {% set hasError = field.vars.errors|length > 0 %}
                    {{ form_widget(field, { attr: {
                        class: 'w-full rounded-lg border px-4 py-2.5 text-sm text-warm-900 placeholder-warm-400 transition-colors focus:outline-none focus:ring-1 '
                            ~ (hasError
                                ? 'border-red-500 bg-red-50 focus:border-red-500 focus:ring-red-500'
                                : 'border-warm-300 bg-white focus:border-accent-500 focus:ring-accent-500')
                    } }) }}

                    {# Live validation errors #}
                    {% if hasError %}
                        <p class="mt-1 text-sm text-red-600">
                            {{ form_errors(field) }}
                        </p>
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}

        {# Buttons — save() calls the PHP method via Live Component #}
        <div class="flex items-center gap-4 pt-4">
            <button
                type="button"
                data-action="live#action"
                data-live-action-param="save"
                class="cursor-pointer rounded-lg bg-warm-900 px-6 py-2.5 text-sm font-medium text-warm-50 transition-colors hover:bg-accent-700"
            >
                Speichern
            </button>
            <a href="{{ path('app_club_planner') }}" class="text-sm text-warm-500 hover:text-warm-700 transition-colors">
                Abbrechen
            </a>
        </div>

    {{ form_end(form) }}
</div>
