{# Reusable "Under the Hood" section. Embed and fill the "items" block. #}
<details class="group mt-6 rounded-xl border border-warm-200">
    <summary class="flex cursor-pointer list-none items-center gap-3 px-5 py-3 text-sm font-semibold tracking-wide text-warm-500 transition-all hover:text-accent-600 [&::-webkit-details-marker]:hidden">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent-600/10 text-accent-600">
            <svg class="h-[22px] w-[22px]" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <rect x="2" y="3" width="20" height="17" rx="2" stroke-width="1.5"/>
                <path d="M2 8h20" stroke-width="1.5"/>
                <circle cx="5.5" cy="5.5" r="1" fill="currentColor" stroke="none"/>
                <circle cx="8" cy="5.5" r="1" fill="currentColor" stroke="none"/>
                <circle cx="10.5" cy="5.5" r="1" fill="currentColor" stroke="none"/>
                <path d="M8 11L5 14L8 17M16 11L19 14L16 17M13.5 10.5L10.5 17.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
        Unter der Haube
        <svg class="ml-auto h-3.5 w-3.5 shrink-0 text-warm-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
    </summary>

    <div class="px-5 pb-5 mt-5 grid gap-5 sm:grid-cols-2">
        {% block items %}{% endblock %}
    </div>
</details>
