{% extends 'base.html.twig' %}

{% block title %}NHL Standings{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module" src="{{ asset('nhl-build/nhl-app.js') }}"></script>
{% endblock %}

{% block body %}
    <section class="py-12">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600">
            Tech Demo
        </p>
        <h1 class="mt-3 font-heading text-4xl text-warm-900">NHL Standings</h1>
        <p class="mt-4 max-w-lg text-warm-500 leading-relaxed">
            Aktuelle NHL-Tabelle mit Team-Rosters.
            Entwickelt mit React und TypeScript — Daten von der öffentlichen NHL API über einen Symfony-Proxy.
        </p>
        {# ===== Unter der Haube ===== #}
        {% embed 'components/_unter_der_haube.html.twig' %}
            {% block items %}
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">React + TypeScript</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        Die gesamte App ist in TypeScript geschrieben. Typisierte Interfaces für
                        API-Daten sorgen dafür, dass Fehler schon bei der Entwicklung auffallen.
                    </p>
                </div>
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">Custom Hooks</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        useStandings() und useRoster() kapseln die Fetch-Logik inklusive Loading- und
                        Error-State. AbortController verhindert Race Conditions bei schnellem Team-Wechsel.
                        Daten werden client-seitig gefiltert — kein Re-Fetch bei Filter-Wechsel.
                    </p>
                </div>
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">Vite Build Pipeline</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        Eigene Build-Pipeline getrennt vom AssetMapper. Vite kompiliert TSX zu JavaScript
                        und bündelt React in eine einzige Datei.
                    </p>
                </div>
                <div class="border-l-2 border-accent-500/30 pl-4">
                    <h3 class="text-sm font-semibold text-warm-900">NHL API + Symfony-Proxy</h3>
                    <p class="mt-1 text-sm text-warm-500 leading-relaxed">
                        Symfony leitet API-Requests an die öffentliche NHL API weiter —
                        React bleibt von CORS-Einschränkungen entkoppelt.
                    </p>
                </div>
            {% endblock %}
        {% endembed %}
    </section>

    {# React App Mount Point #}
    <div class="py-8 border-t border-warm-200">
        <div id="nhl-app"></div>
    </div>
{% endblock %}
